          },
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "additionalProperties": false,
                      "properties": {
                        "format": {
                          "enum": [
                            "tree",
                          ],
                          "type": "string",
                        },
                        "roots": {
                          "items": {
                            "$ref": "#/components/schemas/schema0",
                          },
                          "type": "array",
