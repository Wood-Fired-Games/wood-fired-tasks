                                  {
                                    "enum": [
                                      1,
                                    ],
                                    "type": "number",
                                  },
                                  {
                                    "enum": [
                                      2,
                                    ],
                                    "type": "number",
                                  },
                                  {
                                    "enum": [
                                      3,
