    "/api/v1/tasks/": {
      "get": {
        "description": "List tasks with optional filters (paginated). Returns \`{ data, total, limit, offset }\` — \`limit\` defaults to 50, max 500.",
        "parameters": [
          {
            "in": "query",
            "name": "project_id",
            "required": false,
            "schema": {
              "exclusiveMinimum": true,
              "maximum": 9007199254740991,
              "minimum": 0,
              "type": "integer",
            },
          },
          {
            "in": "query",
            "name": "status",
            "required": false,
            "schema": {
              "enum": [
                "open",
                "in_progress",
                "done",
                "closed",
                "blocked",
                "backlogged",
              ],
              "type": "string",
            },
          },
          {
            "in": "query",
            "name": "assignee",
            "required": false,
            "schema": {
              "type": "string",
            },
          },
          {
            "in": "query",
            "name": "tags",
            "required": false,
            "schema": {
              "type": "string",
            },
          },
          {
            "in": "query",
            "name": "due_before",
            "required": false,
            "schema": {
              "format": "date-time",
              "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$",
              "type": "string",
            },
          },
