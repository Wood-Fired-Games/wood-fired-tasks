    "/api/v1/projects/{id}/topology": {
      "get": {
        "description": "Classify a project as FLAT (parallelizable, /tasks:loop), DAG (wave-by-wave parallel dispatch, /tasks:loop-dag), or DAG_CYCLIC (BLOCKED) based on its task_dependencies graph. Returns topology, edges, roots, leaves, and an execution advisory.",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "exclusiveMinimum": true,
              "maximum": 9007199254740991,
              "minimum": 0,
              "type": "integer",
            },
          },
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "properties": {
                    "advisory": {
                      "enum": [
                        "/tasks:loop",
                        "/tasks:loop-dag",
                        "BLOCKED",
                      ],
                      "type": "string",
                    },
                    "edges": {
                      "items": {
                        "additionalProperties": false,
                        "properties": {
                          "from": {
                            "exclusiveMinimum": true,
                            "maximum": 9007199254740991,
                            "minimum": 0,
                            "type": "integer",
                          },
                          "to": {
                            "exclusiveMinimum": true,
                            "maximum": 9007199254740991,
                            "minimum": 0,
                            "type": "integer",
                          },
                        },
                        "required": [
                          "from",
                          "to",
                        ],
                        "type": "object",
                      },
                      "type": "array",
                    },
                    "leaves": {
                      "items": {
                        "exclusiveMinimum": true,
                        "maximum": 9007199254740991,
                        "minimum": 0,
                        "type": "integer",
                      },
                      "type": "array",
                    },
                    "roots": {
                      "items": {
                        "exclusiveMinimum": true,
                        "maximum": 9007199254740991,
                        "minimum": 0,
                        "type": "integer",
                      },
                      "type": "array",
                    },
                    "topology": {
                      "enum": [
                        "FLAT",
                        "DAG",
                        "DAG_CYCLIC",
                      ],
                      "type": "string",
                    },
                  },
                  "required": [
                    "topology",
                    "edges",
                    "roots",
                    "leaves",
                    "advisory",
                  ],
                  "type": "object",
                },
              },
            },
            "description": "Default Response",
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "properties": {
                    "details": {},
                    "error": {
                      "type": "string",
                    },
                    "message": {
                      "type": "string",
                    },
                  },
                  "required": [
                    "error",
                    "message",
                  ],
                  "type": "object",
                },
              },
            },
            "description": "Default Response",
          },
        },
        "tags": [
          "projects",
        ],
      },
    },
    "/api/v1/projects/{id}/wsjf-health": {
      "get": {
        "description": "Lint a project's WSJF state for degeneracies and pitfalls (non-blocking, pure read). Reports near-identical scores, a missing Cost-of-Delay \`1\` anchor, a collapsed Job Size distribution, past-deadline stale Time Criticality, a high priority-fallback ratio, and score-churn. Each finding carries a severity, message, and suggested fix. Empty findings ⇔ healthy. Identical to the stdio \`wsjf_health\` tool.",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "exclusiveMinimum": true,
              "maximum": 9007199254740991,
              "minimum": 0,
              "type": "integer",
            },
          },
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "properties": {
                    "findings": {
                      "items": {
                        "additionalProperties": false,
                        "properties": {
                          "check": {
                            "enum": [
                              "degenerate-spread",
                              "cod-no-anchor",
                              "job-size-collapsed",
                              "stale-time-criticality",
                              "high-fallback-ratio",
                              "score-churn",
                            ],
                            "type": "string",
                          },
                          "message": {
                            "type": "string",
                          },
                          "severity": {
                            "enum": [
                              "info",
                              "warning",
                              "critical",
                            ],
                            "type": "string",
                          },
                          "suggestion": {
                            "type": "string",
                          },
                          "taskIds": {
                            "items": {
                              "type": "number",
                            },
                            "type": "array",
                          },
                        },
                        "required": [
                          "check",
                          "severity",
                          "message",
                          "suggestion",
                          "taskIds",
                        ],
                        "type": "object",
                      },
                      "type": "array",
                    },
                    "healthy": {
                      "type": "boolean",
                    },
                    "project_id": {
                      "exclusiveMinimum": true,
                      "maximum": 9007199254740991,
                      "minimum": 0,
                      "type": "integer",
                    },
                    "scored_task_count": {
                      "maximum": 9007199254740991,
                      "minimum": 0,
                      "type": "integer",
                    },
                  },
                  "required": [
                    "project_id",
                    "healthy",
                    "scored_task_count",
                    "findings",
                  ],
                  "type": "object",
                },
              },
            },
            "description": "Default Response",
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "properties": {
                    "details": {},
                    "error": {
                      "type": "string",
                    },
                    "message": {
                      "type": "string",
                    },
                  },
                  "required": [
                    "error",
                    "message",
                  ],
                  "type": "object",
                },
              },
            },
            "description": "Default Response",
          },
        },
        "tags": [
          "projects",
        ],
      },
    },
    "/api/v1/projects/{id}/wsjf-ranking": {
      "get": {
        "description": "Rank a project's tasks by propagation-adjusted WSJF. \`scope=frontier\` (default) excludes not-ready/blocked tasks; \`scope=all\` ranks every task. Returns an ordered list (descending effective WSJF), each entry carrying its components, base vs effective WSJF, and the downstream Cost-of-Delay propagation breakdown. Identical to the stdio \`wsjf_ranking\` tool.",
        "parameters": [
          {
            "in": "query",
            "name": "scope",
            "required": false,
            "schema": {
              "enum": [
                "frontier",
                "all",
              ],
              "type": "string",
