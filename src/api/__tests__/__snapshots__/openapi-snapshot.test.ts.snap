    "/api/v1/tasks/{id}/subtasks": {
      "get": {
        "description": "Get subtasks (children) of a task (paginated). Returns \`{ data, total, limit, offset }\`.",
        "parameters": [
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": 50,
              "exclusiveMinimum": true,
              "maximum": 500,
              "minimum": 0,
              "type": "integer",
            },
          },
          {
            "in": "query",
            "name": "offset",
            "required": false,
            "schema": {
              "default": 0,
              "maximum": 9007199254740991,
              "minimum": 0,
              "type": "integer",
            },
          },
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "exclusiveMinimum": true,
              "maximum": 9007199254740991,
              "minimum": 0,
              "type": "integer",
            },
          },
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": false,
                  "properties": {
                    "data": {
                      "items": {
                        "additionalProperties": false,
                        "properties": {
                          "acceptance_criteria": {
                            "nullable": true,
                            "type": "string",
                          },
                          "assignee": {
                            "nullable": true,
                            "type": "string",
                          },
                          "claimed_at": {
                            "nullable": true,
                            "type": "string",
                          },
                          "created_at": {
                            "type": "string",
                          },
                          "created_by": {
                            "type": "string",
                          },
                          "description": {
                            "nullable": true,
                            "type": "string",
                          },
                          "due_date": {
                            "nullable": true,
                            "type": "string",
                          },
                          "estimated_minutes": {
                            "nullable": true,
                            "type": "number",
                          },
                          "id": {
                            "type": "number",
                          },
                          "parent_task_id": {
                            "nullable": true,
                            "type": "number",
                          },
                          "priority": {
                            "enum": [
                              "low",
                              "medium",
                              "high",
                              "urgent",
                            ],
                            "type": "string",
                          },
                          "project_id": {
                            "type": "number",
                          },
                          "project_name": {
                            "type": "string",
                          },
                          "status": {
                            "enum": [
                              "open",
                              "in_progress",
                              "done",
                              "closed",
                              "blocked",
                              "backlogged",
                            ],
                            "type": "string",
                          },
                          "tags": {
                            "items": {
                              "type": "string",
                            },
                            "type": "array",
                          },
                          "title": {
                            "type": "string",
                          },
                          "updated_at": {
                            "type": "string",
                          },
                          "verification_evidence": {
                            "additionalProperties": false,
                            "nullable": true,
                            "properties": {
                              "checks": {
                                "items": {
                                  "additionalProperties": false,
                                  "properties": {
                                    "evidence_url_or_text": {
                                      "maxLength": 2000,
                                      "type": "string",
                                    },
                                    "name": {
                                      "maxLength": 200,
                                      "minLength": 1,
                                      "type": "string",
                                    },
                                    "status": {
                                      "enum": [
                                        "PASS",
                                        "FAIL",
                                        "SKIP",
                                      ],
                                      "type": "string",
                                    },
                                  },
                                  "required": [
                                    "name",
                                    "status",
                                    "evidence_url_or_text",
                                  ],
                                  "type": "object",
                                },
                                "maxItems": 50,
                                "type": "array",
                              },
                              "verdict": {
                                "enum": [
                                  "PASS",
                                  "FAIL",
                                  "PARTIAL",
                                  "NOT_VERIFIED",
                                ],
                                "type": "string",
                              },
                              "verified_at": {
                                "format": "date-time",
                                "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$",
                                "type": "string",
                              },
                              "verifier_request_id": {
                                "maxLength": 200,
                                "minLength": 1,
                                "type": "string",
                              },
                              "verifier_session_id": {
                                "maxLength": 200,
                                "minLength": 1,
                                "type": "string",
                              },
                            },
                            "required": [
                              "verdict",
                            ],
                            "type": "object",
                          },
                          "version": {
                            "type": "number",
                          },
                        },
                        "required": [
                          "id",
                          "title",
                          "description",
                          "status",
                          "priority",
                          "project_id",
                          "project_name",
                          "parent_task_id",
                          "estimated_minutes",
                          "assignee",
                          "created_by",
                          "due_date",
                          "created_at",
                          "updated_at",
                          "version",
                          "claimed_at",
                          "tags",
                          "acceptance_criteria",
                          "verification_evidence",
                        ],
                        "type": "object",
                      },
                      "type": "array",
                    },
                    "limit": {
                      "exclusiveMinimum": true,
                      "maximum": 9007199254740991,
                      "minimum": 0,
                      "type": "integer",
                    },
                    "offset": {
                      "maximum": 9007199254740991,
                      "minimum": 0,
                      "type": "integer",
                    },
                    "total": {
                      "maximum": 9007199254740991,
                      "minimum": 0,
                      "type": "integer",
                    },
                  },
                  "required": [
                    "data",
                    "total",
                    "limit",
                    "offset",
                  ],
                  "type": "object",
                },
              },
            },
            "description": "Default Response",
          },
        },
        "tags": [
          "tasks",
        ],
      },
    },
