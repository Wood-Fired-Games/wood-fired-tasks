# wood-fired-tasks environment configuration
# Copy to .env and edit. See docs/SETUP.md for the full reference.
#
# This example is tuned for LOCAL DEVELOPMENT. For production, see
# deploy/wood-fired-tasks.env.example instead.

# --- Server -----------------------------------------------------------------
# NODE_ENV: development | production | test
NODE_ENV=development
# PORT: HTTP port the API/MCP HTTP transport listens on.
PORT=3000
# HOST: Bind interface. 127.0.0.1 (loopback) is the safe default.
#       Set HOST=0.0.0.0 only when you intentionally want LAN exposure.
HOST=127.0.0.1
# LOG_LEVEL: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# --- Authentication ---------------------------------------------------------
# Three strategies are tried in order: PAT (Bearer wft_pat_…) → session
# (sealed-box cookie from OIDC) → legacy (X-API-Key against API_KEYS).
# Legacy is deprecated; see SECURITY.md → Legacy Auth Sunset Timeline.
#
# Strategy 3: Legacy X-API-Key (still works through the v1.7 sunset date).
# API_KEYS: comma-separated. Each key grants full admin power. Bare keys
# auto-derive a log label; use "key:label" to set one explicitly.
# Example: API_KEYS=dev-key-1,dev-key-2:ci-bot
API_KEYS=replace-with-your-api-key

# LEGACY_AUTH_SUNSET_DATE: date when X-API-Key auth will be removed (v1.7).
# Sent as the `Sunset:` response header on every legacy-authed REST request
# (RFC 8594). Must be YYYY-MM-DD and a valid calendar date.
# Default: 2026-12-31 (six months after v1.6 ship).
#LEGACY_AUTH_SUNSET_DATE=2026-12-31

# Strategy 2: OIDC session cookie (recommended for browser users).
# Leave all four OIDC_* unset to disable OIDC; PAT + legacy auth keep working.
# Required: register a Google OAuth client and add the redirect URI to
# the "Authorised redirect URIs" list. See docs/SETUP.md → OIDC (Google)
# Configuration for the full walk-through.
# OIDC_ISSUER_URL=https://accounts.google.com
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=http://127.0.0.1:3000/auth/callback
# OIDC_SCOPES=openid email profile

# Required when OIDC is enabled. Generate with: openssl rand -base64 32
# Must decode to exactly 32 bytes (sodium sealed-box key). Rotating this
# value invalidates every active session — users must log in again.
# SESSION_COOKIE_SECRET=
# SESSION_COOKIE_NAME=wft_session

# Strategy 1: PAT (Personal Access Token). No env var here — PATs are
# minted from a logged-in /me web session OR offline via:
#   node dist/cli/bin/tasks.js db mint-token --user-email <addr>
# Clients pass the value as `Authorization: Bearer wft_pat_<…>` (REST),
# or set WFT_API_KEY=<pat> (MCP) / API_KEY=<pat> (CLI) — both surfaces
# auto-detect the wft_pat_ prefix.

# --- Database ---------------------------------------------------------------
# DATABASE_PATH is the canonical name. DB_PATH is a deprecated alias.
DATABASE_PATH=./data/tasks.db

# --- CLI (optional) ---------------------------------------------------------
# Used by the bugs-cli to reach this server. Match API_KEYS above.
API_BASE_URL=http://localhost:3000

# --- Slack integration (optional) -------------------------------------------
# Leave unset to disable Slack. If you set ANY Slack var, you MUST set
# SLACK_BOT_TOKEN and SLACK_APP_TOKEN together. See docs/SLACK.md for setup.
# Real tokens begin with xoxb- (bot) and xapp- (app). The placeholders below
# are intentionally not valid tokens — replace before enabling Slack.
#SLACK_BOT_TOKEN=replace-with-bot-token-xoxb
#SLACK_APP_TOKEN=replace-with-app-token-xapp
#SLACK_SIGNING_SECRET=replace-with-signing-secret
