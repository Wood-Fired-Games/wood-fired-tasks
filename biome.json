{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "**",
      "!**/dist/**",
      "!**/node_modules/**",
      "!**/coverage/**",
      "!**/reports/**",
      "!**/.stryker-tmp/**",
      "!**/.codex/**",
      "!**/.planning/**",
      "!**/.claude/**",
      "!**/.agents/**",
      "!**/data/**",
      "!**/tmp/**",
      "!**/*.db",
      "!**/*.db-wal",
      "!**/*.db-shm",
      "!**/package-lock.json"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all",
      "arrowParentheses": "always",
      "bracketSpacing": true,
      "bracketSameLine": false
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": false,
      "suspicious": {
        "noConsole": {
          "level": "error",
          "options": {
            "allow": ["error", "warn"]
          }
        },
        "noTsIgnore": "error"
      },
      "nursery": {
        "noFloatingPromises": "error",
        "noMisusedPromises": "error"
      }
    }
  },
  "assist": {
    "enabled": false
  },
  "overrides": [
    {
      "includes": [
        "src/cli/**",
        "src/mcp/**",
        "scripts/**",
        "src/index.ts",
        "src/db/migrate.ts",
        "packages/wft-router/src/bin/**"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": {
              "level": "error",
              "options": {
                "allow": ["error", "warn", "log", "info"]
              }
            }
          }
        }
      }
    },
    {
      "includes": [
        "**/__tests__/**",
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/*.spec.ts",
        "**/*.property.test.ts"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    },
    {
      "includes": [
        "**/__tests__/**",
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/*.spec.ts",
        "**/*.property.test.ts",
        "**/*.bench.ts",
        "scripts/**",
        "docs/**",
        "*.mjs",
        "*.cjs",
        "*.js"
      ],
      "linter": {
        "rules": {
          "nursery": {
            "noFloatingPromises": "off",
            "noMisusedPromises": "off"
          }
        }
      }
    }
  ]
}
