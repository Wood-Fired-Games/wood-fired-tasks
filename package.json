{
  "name": "wood-fired-tasks",
  "version": "1.0.0",
  "description": "Network-wide task tracking system for Wood Fired Games",
  "keywords": [
    "task-tracker",
    "bug-tracker",
    "mcp",
    "model-context-protocol",
    "fastify",
    "cli",
    "slack-integration",
    "sqlite",
    "typescript",
    "claude-code",
    "agents",
    "agents-md",
    "agent-context",
    "agent-friendly",
    "ai-agents",
    "rest-api",
    "event-bus"
  ],
  "author": "Wood Fired Games",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Wood-Fired-Games/wood-fired-tasks.git"
  },
  "bugs": {
    "url": "https://github.com/Wood-Fired-Games/wood-fired-tasks/issues"
  },
  "homepage": "https://github.com/Wood-Fired-Games/wood-fired-tasks#readme",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "tasks": "./dist/cli/bin/tasks.js"
  },
  "files": [
    "dist/",
    "!dist/**/__tests__/**",
    "!dist/**/*.test.*",
    "!dist/**/*.property.test.*",
    "!dist/wood-fired-tasks-client.zip",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "SECURITY.md",
    "AGENTS.md",
    "CLAUDE.md",
    "llms.txt",
    "docs/AGENT_CONTEXT.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/api/start.js",
    "dev": "tsx src/api/start.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:bench": "vitest bench --run",
    "migrate": "tsx src/db/migrate.ts",
    "cli": "tsx src/cli/bin/tasks.ts",
    "mcp:start": "node dist/mcp/index.js",
    "mcp:dev": "tsx src/mcp/index.ts",
    "mcp:remote": "node dist/mcp/remote/index.js",
    "lint": "biome check .",
    "format:check": "echo 'format:check is unavailable: biome.json has formatter.enabled=false. Enable the formatter in a dedicated follow-up PR before re-adding this gate.' >&2 && exit 1",
    "format": "biome format --write .",
    "lint:deps": "knip --dependencies",
    "depcruise": "depcruise src --config .dependency-cruiser.cjs",
    "depcruise:graph": "depcruise src --config .dependency-cruiser.cjs --output-type dot --output-to dependency-graph.dot",
    "test:mutation": "stryker run",
    "pack:check": "npm pack --dry-run",
    "agent-context:gen": "tsx scripts/agent-context/generate.ts",
    "agent-context:check": "tsx scripts/agent-context/check.ts",
    "quality": "npm run build && npm test && npm run lint && npm run lint:deps && npm run depcruise && npm audit --omit=dev --audit-level=high",
    "prepublishOnly": "npm run build && npm test && npm run lint:deps && npm audit --omit=dev --audit-level=high && npm run pack:check"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/formbody": "^8.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/secure-session": "^8.3.0",
    "@fastify/sse": "^0.4.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@slack/bolt": "^4.6.0",
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "openid-client": "^6.8.4",
    "smol-toml": "^1.6.1",
    "umzug": "^3.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@fast-check/vitest": "^0.4.1",
    "@slack/types": "^2.20.0",
    "@slack/web-api": "^7.15.2",
    "@stryker-mutator/core": "^9.5.1",
    "@stryker-mutator/typescript-checker": "^9.5.1",
    "@stryker-mutator/vitest-runner": "^9.5.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "cheerio": "^1.2.0",
    "dependency-cruiser": "17.4.0",
    "knip": "^6.14.2",
    "nock": "^14.0.15",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.18"
  }
}
