{
  "name": "wood-fired-bugs",
  "version": "1.0.0",
  "description": "Network-wide task tracking system for Wood Fired Games",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "tasks": "./dist/cli/bin/tasks.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/api/start.js",
    "dev": "tsx src/api/start.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "migrate": "tsx src/db/migrate.ts",
    "cli": "tsx src/cli/bin/tasks.ts",
    "mcp:start": "node dist/mcp/index.js",
    "mcp:dev": "tsx src/mcp/index.ts",
    "mcp:remote": "node dist/mcp/remote/index.js",
    "lint:deps": "knip --dependencies",
    "test:mutation": "stryker run"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@clack/prompts": "^1.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sse": "^0.4.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@slack/bolt": "^4.6.0",
    "better-sqlite3": "^12.6.2",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "umzug": "^3.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@fast-check/vitest": "^0.2.4",
    "@slack/types": "^2.20.0",
    "@slack/web-api": "^7.15.2",
    "@stryker-mutator/core": "^9.5.1",
    "@stryker-mutator/typescript-checker": "^9.5.1",
    "@stryker-mutator/vitest-runner": "^9.5.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "knip": "^5.83.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
