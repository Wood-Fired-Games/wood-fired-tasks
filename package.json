{
  "name": "wood-fired-tasks",
  "version": "2.0.1",
  "description": "Network-wide task tracking system for Wood Fired Games",
  "keywords": [
    "task-tracker",
    "bug-tracker",
    "mcp",
    "model-context-protocol",
    "fastify",
    "cli",
    "slack-integration",
    "sqlite",
    "typescript",
    "claude-code",
    "agents",
    "agents-md",
    "agent-context",
    "agent-friendly",
    "ai-agents",
    "rest-api",
    "event-bus"
  ],
  "author": "Wood Fired Games",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Wood-Fired-Games/wood-fired-tasks.git"
  },
  "bugs": {
    "url": "https://github.com/Wood-Fired-Games/wood-fired-tasks/issues"
  },
  "homepage": "https://github.com/Wood-Fired-Games/wood-fired-tasks#readme",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "wood-fired-tasks": "./dist/cli/bin/tasks.js",
    "wft": "./dist/cli/bin/tasks.js",
    "tasks": "./dist/cli/bin/tasks.js",
    "wft-router": "./packages/wft-router/dist/bin/wft-router.js"
  },
  "files": [
    "dist/",
    "scripts/postinstall.cjs",
    "!dist/**/__tests__/**",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*",
    "!dist/**/*.property.test.*",
    "!dist/**/*.map",
    "packages/wft-router/dist/",
    "!packages/wft-router/dist/**/__tests__/**",
    "!packages/wft-router/dist/**/*.test.*",
    "!packages/wft-router/dist/**/*.spec.*",
    "!packages/wft-router/dist/**/*.map",
    "packages/wft-router/package.json",
    "packages/wft-router/README.md",
    "packages/wft-router/triggers.example.yaml",
    "dist/skills/tasks/",
    "dist/skills/agents/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "SECURITY.md",
    "AGENTS.md",
    "CLAUDE.md",
    "llms.txt",
    "docs/AGENT_CONTEXT.md",
    "docs/README.md",
    "docs/NAVIGATION.md",
    "docs/SETUP.md",
    "docs/CLI.md",
    "docs/API.md",
    "docs/MCP.md",
    "docs/INTERFACES.md",
    "docs/USAGE_PATTERNS.md",
    "docs/WORKFLOWS.md",
    "docs/SLACK.md",
    "docs/RELIABILITY.md",
    "docs/TROUBLESHOOTING.md",
    "docs/ARCHITECTURE.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc && tsc -p packages/wft-router && npm run build:skills",
    "build:skills": "tsx scripts/build-skills.ts",
    "start": "node dist/api/start.js",
    "dev": "tsx src/api/start.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:bench": "vitest bench --run",
    "migrate": "tsx src/db/migrate.ts",
    "postinstall": "node scripts/postinstall.cjs",
    "smoke": "./scripts/smoke/fresh-clone-smoke.sh",
    "smoke:global": "node scripts/smoke-global.mjs",
    "cli": "tsx src/cli/bin/tasks.ts",
    "mcp:start": "node dist/mcp/index.js",
    "mcp:dev": "tsx src/mcp/index.ts",
    "mcp:remote": "node dist/mcp/remote/index.js",
    "lint": "biome check .",
    "format:check": "biome format .",
    "format": "biome format --write .",
    "lint:deps": "knip --dependencies",
    "quality:complexity": "node scripts/quality/complexity-report.mjs",
    "depcruise": "depcruise src packages/wft-router/src --config .dependency-cruiser.cjs",
    "depcruise:graph": "depcruise src packages/wft-router/src --config .dependency-cruiser.cjs --output-type dot --output-to dependency-graph.dot",
    "test:mutation": "stryker run",
    "publint": "publint",
    "pack:check": "publint && node scripts/pack-check.mjs",
    "agent-context:gen": "tsx scripts/agent-context/generate.ts",
    "agent-context:check": "tsx scripts/agent-context/check.ts",
    "check:vendor-neutrality": "node scripts/vendor-neutrality/check.mjs",
    "quality": "npm run build && npm test && npm run lint && npm run format:check && npm run lint:deps && npm run depcruise && npm audit --omit=dev --audit-level=high",
    "quality:fast": "npm run build && npm test && npm run lint && npm run format:check && npm run lint:deps && npm run depcruise",
    "quality:full": "npm run quality",
    "prepublishOnly": "npm run build && npm test && npm run lint:deps && npm audit --omit=dev --audit-level=high && npm run pack:check"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/formbody": "^8.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/secure-session": "^8.3.0",
    "@fastify/sse": "^0.4.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@slack/bolt": "^4.6.0",
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^15.0.0",
    "dotenv": "^17.3.1",
    "env-paths": "^4.0.0",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "openid-client": "^6.8.4",
    "pino": "^10.3.1",
    "smol-toml": "^1.6.1",
    "umzug": "^3.8.2",
    "update-notifier": "^7.3.1",
    "yaml": "^2.6.1",
    "zod": "^4.3.6"
  },
  "overrides": {
    "qs": "^6.15.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@fast-check/vitest": "^0.4.1",
    "@slack/types": "^2.20.0",
    "@slack/web-api": "^7.15.2",
    "@stryker-mutator/core": "^9.5.1",
    "@stryker-mutator/typescript-checker": "^9.5.1",
    "@stryker-mutator/vitest-runner": "^9.5.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "cheerio": "^1.2.0",
    "dependency-cruiser": "17.4.3",
    "knip": "^6.14.2",
    "nock": "^14.0.15",
    "pino-pretty": "^13.1.3",
    "publint": "^0.3.21",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.18"
  }
}
