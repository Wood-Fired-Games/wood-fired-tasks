# EXAMPLE EnvironmentFile for the wft-router systemd unit.
# Copy to /etc/wft-router/wft-router.env (chmod 0640, root:root or the service
# user) and fill in real values. Do NOT commit a populated copy — it holds a
# secret token.
#
# systemd EnvironmentFile syntax: KEY=value, one per line, no `export`, no shell
# expansion. Quote only if the value contains spaces.

# Tasks API base URL the router polls/dispatches against.
WFT_ROUTER_ENDPOINT=https://tasks.example.com

# API token / key. Treat as a secret.
WFT_ROUTER_TOKEN=replace-me

# Log verbosity: error | warn | info | debug
LOG_LEVEL=info

# Path overrides are set in the unit (Environment=) so DynamicUser/StateDirectory
# line up; uncomment here only if you are NOT using DynamicUser.
#WFT_ROUTER_CONFIG=/etc/wft-router
#WFT_ROUTER_STATE_DIR=/var/lib/wft-router/state
#WFT_ROUTER_DATA_DIR=/var/lib/wft-router/data
