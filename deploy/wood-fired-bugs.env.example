# Wood Fired Bugs - Environment Configuration
# Copy this file to /opt/wood-fired-bugs/.env and fill in values

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# Logging
LOG_LEVEL=info

# Authentication (comma-separated API keys)
API_KEYS=change-me-to-a-real-key

# Database
DB_PATH=/opt/wood-fired-bugs/data/tasks.db
