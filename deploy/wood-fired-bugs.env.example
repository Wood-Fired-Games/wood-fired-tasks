# wood-fired-bugs - production environment configuration
# Copy this file to /opt/wood-fired-bugs/.env and fill in real values.
# See docs/SETUP.md for the full reference and docs/SLACK.md for Slack setup.
#
# This example targets a PRODUCTION deploy (systemd unit, /opt install).
# For local development, see the root .env.example instead.

# --- Server -----------------------------------------------------------------
NODE_ENV=production
PORT=3000
# HOST=0.0.0.0 exposes the service on every interface. Restrict via firewall
# or reverse proxy. Bind to 127.0.0.1 if you front the service with nginx on
# the same host.
HOST=0.0.0.0

# --- Logging ----------------------------------------------------------------
# Production default is info. Use warn or error for quieter logs.
LOG_LEVEL=info

# --- Authentication ---------------------------------------------------------
# API_KEYS: comma-separated. Each key grants full admin power. Generate with
# `openssl rand -hex 32` (one per agent/client). Use "key:label" to attribute
# requests in audit logs, e.g. "abc123:ci-bot,def456:laptop-alice".
# REQUIRED — the placeholder below is not a real key.
API_KEYS=REPLACE_WITH_GENERATED_KEY

# --- Database ---------------------------------------------------------------
# DATABASE_PATH is the canonical name (DB_PATH is a deprecated alias kept for
# older installs). Path must be writable by the service user.
DATABASE_PATH=/opt/wood-fired-bugs/data/tasks.db

# --- Slack integration (optional) -------------------------------------------
# Leave unset to disable Slack. If you set ANY Slack var, you MUST set both
# SLACK_BOT_TOKEN and SLACK_APP_TOKEN. See docs/SLACK.md for full setup.
# Real tokens begin with xoxb- (bot) and xapp- (app). The placeholders below
# are intentionally not valid — replace with values from your Slack app.
#SLACK_BOT_TOKEN=REPLACE_WITH_BOT_TOKEN_xoxb
#SLACK_APP_TOKEN=REPLACE_WITH_APP_TOKEN_xapp
#SLACK_SIGNING_SECRET=REPLACE_WITH_SIGNING_SECRET
